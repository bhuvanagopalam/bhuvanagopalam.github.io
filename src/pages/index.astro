---
import ExperienceSection from "../components/ExperienceSection.astro";
import Hero from "../components/Hero.astro";
import PresentationsSection from "../components/PresentationsSection.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ResearchOutputsSection from "../components/ResearchOutputsSection.astro";
import SkillsSection from "../components/SkillsSection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile } from "../data/profile";
---

<BaseLayout
  title="Rushendra"
  seoTitle={`${profile.name} | Applied AI and Machine Learning`}
  description={profile.summary}
>
  <Hero />

  <SkillsSection />

  <ExperienceSection />

  <ProjectsSection />

  <ResearchOutputsSection />

  <PresentationsSection />
</BaseLayout>
