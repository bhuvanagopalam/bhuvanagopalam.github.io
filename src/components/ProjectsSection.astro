---
import { projects } from "../data/projects";
---

<section class="section compact-section" id="projects" aria-labelledby="projects-title">
  <div class="container">
    <div class="compact-heading">
      <h2 id="projects-title">Projects</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="project-grid">
      {
        projects.map((project) => (
          <article class="project-card">
            <div class="project-card__content">
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
            </div>

            <div class="project-card__stack">
              <span>Stack</span>
              <ul aria-label={`${project.title} stack`}>
                {project.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>

            <div class="project-card__footer">
              {
                project.links?.length ? (
                  <ul class="project-card__links" aria-label={`${project.title} links`}>
                    {project.links.map((link) => (
                      <li>
                        <a href={link.href} target="_blank" rel="noreferrer">
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                ) : (
                  <span class="project-card__link-muted">Link pending</span>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
