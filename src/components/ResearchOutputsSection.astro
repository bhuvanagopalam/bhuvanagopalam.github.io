---
import { publications } from "../data/publications";
---

<section class="section compact-section" id="publications" aria-labelledby="publications-title">
  <div class="container">
    <div class="compact-heading">
      <h2 id="publications-title">Research Outputs</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="research-grid">
      {
        publications.map((publication) => (
          <article class="research-card">
            <div class="research-card__top">
              <span class="research-card__year">{publication.year}</span>
              <p class="research-card__venue">{publication.venue}</p>
            </div>

            <div class="research-card__body">
              <h3>{publication.title}</h3>
              <p>{publication.summary}</p>
            </div>

            <p class="research-card__authors">{publication.authors}</p>

            <ul class="compact-links research-card__links" aria-label={`${publication.title} links`}>
              {
                publication.links.map((link) => (
                  <li>
                    <a href={link.href} target="_blank" rel="noreferrer">
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
