---
import { experience } from "../data/experience";

const monthOrder: Record<string, number> = {
  January: 1,
  February: 2,
  March: 3,
  April: 4,
  May: 5,
  June: 6,
  July: 7,
  August: 8,
  September: 9,
  October: 10,
  November: 11,
  December: 12,
};

function getSortValue(date: string) {
  if (date === "Present") {
    return Number.MAX_SAFE_INTEGER;
  }

  const [month, year] = date.split(" ");
  return Number(year) * 12 + (monthOrder[month] ?? 0);
}

const orderedExperience = [...experience].sort(
  (a, b) => getSortValue(b.end) - getSortValue(a.end),
);
---

<section class="section experience-section" id="experience" aria-labelledby="experience-title">
  <div class="container">
    <div class="experience-heading">
      <h2 id="experience-title">Experience</h2>
      <span aria-hidden="true"></span>
    </div>

    <div class="experience-path" aria-label="Experience timeline">
      {
        orderedExperience.map((item) => {
          const dates = `${item.start} - ${item.end}`;
          const skills = item.tags?.slice(0, 5) ?? [];

          return (
            <div class="experience-item">
              <div class="experience-date" aria-label={dates}>
                <strong class="experience-date__end">{item.end}</strong>
                <span class="experience-date__line" aria-hidden="true"></span>
                <span class="experience-date__start">{item.start}</span>
              </div>

              <span class="experience-marker" aria-hidden="true"></span>

              <details class="experience-card">
                <summary>
                  <div class="experience-card__top">
                    <div>
                      <h3>{item.title}</h3>
                      <p class="experience-card__org">{item.organization}</p>
                    </div>
                    <span class="experience-card__period">{dates}</span>
                  </div>

                  {item.location && <p class="experience-card__location">{item.location}</p>}
                  <p class="experience-card__summary">{item.summary}</p>

                  {
                    skills.length > 0 && (
                      <ul class="experience-skills" aria-label={`Key skills for ${item.title}`}>
                        {skills.map((skill) => <li>{skill}</li>)}
                      </ul>
                    )
                  }

                  <span class="experience-card__toggle">View details</span>
                </summary>

                <div class="experience-card__details">
                  <ul>
                    {item.details.map((detail) => <li>{detail}</li>)}
                  </ul>
                </div>
              </details>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
