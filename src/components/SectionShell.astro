---
type Props = {
  id: string;
  kicker: string;
  title: string;
  intro: string;
  placeholder: string;
};

const { id, kicker, title, intro, placeholder } = Astro.props;
---

<section class="section" id={id} aria-labelledby={`${id}-title`}>
  <div class="container">
    <div class="section__header">
      <div>
        <p class="section__kicker">{kicker}</p>
        <h2 class="section__title" id={`${id}-title`}>{title}</h2>
      </div>
      <p class="section__intro">{intro}</p>
    </div>

    <div class="section__placeholder">{placeholder}</div>
  </div>
</section>
